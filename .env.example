# ── Públicas (vão pro navegador — prefixo NEXT_PUBLIC_) ──
NEXT_PUBLIC_SUPABASE_URL=seu_url_do_supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_publishable_do_supabase

# ── Segredos (SÓ servidor — configure na Vercel, NUNCA versione com valor real) ──
SUPABASE_SECRET_KEY=chave_service_role_do_supabase
GEMINI_API_KEY=chave_da_api_gemini
